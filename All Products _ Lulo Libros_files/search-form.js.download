class SearchForm extends HTMLElement{constructor(){super(),this.input=this.querySelector('input[type="search"]'),this.resetButton=this.querySelector('button[type="reset"]'),this.input&&(this.input.form.addEventListener("reset",this.onFormReset.bind(this)),this.input.addEventListener("input",debounce(event=>{this.onChange(event)},300).bind(this)))}toggleResetButton(){if(!this.resetButton)return;const resetIsHidden=this.resetButton.classList.contains("hidden");this.input.value.length>0&&resetIsHidden?this.resetButton.classList.remove("hidden"):this.input.value.length===0&&!resetIsHidden&&this.resetButton.classList.add("hidden")}onChange(){this.toggleResetButton()}shouldResetForm(){return!document.querySelector('[aria-selected="true"] a')}onFormReset(event){event.preventDefault(),this.shouldResetForm()&&(this.input.value="",this.input.focus(),this.toggleResetButton())}}customElements.define("search-form",SearchForm);

(function(){
  var SCRIPT_ID = 'lulo-zxing-library';
  var MODAL_ID = 'lulo-barcode-scanner-modal';
  var BUTTON_CLASS = 'lulo-barcode-scan-button';

  function loadZxing(){
    return new Promise(function(resolve, reject){
      if (window.ZXing) return resolve();
      var existing = document.getElementById(SCRIPT_ID) || document.querySelector('script[src*="@zxing/library"]');
      if (existing) {
        if (window.ZXing) return resolve();
        existing.addEventListener('load', function(){ resolve(); }, { once: true });
        existing.addEventListener('error', reject, { once: true });
        setTimeout(function(){ window.ZXing ? resolve() : reject(new Error('ZXing did not load.')); }, 5000);
        return;
      }
      var script = document.createElement('script');
      script.id = SCRIPT_ID;
      script.src = 'https://unpkg.com/@zxing/library@latest';
      script.onload = function(){ resolve(); };
      script.onerror = reject;
      document.head.appendChild(script);
    });
  }

  function addStyles(){
    if (document.getElementById('lulo-barcode-scanner-styles')) return;
    var style = document.createElement('style');
    style.id = 'lulo-barcode-scanner-styles';
    style.textContent = '\nform[action*="/search"] .field, search-form .field, form[action*="/search"]{position:relative!important;}\n.search__input.field__input, .search-modal__form input[type="search"], form[action*="/search"] input[type="search"]{padding-right:8.8rem!important;}\n.lulo-barcode-scan-button{position:absolute!important;right:5.25rem!important;top:50%!important;transform:translateY(-50%)!important;z-index:2147483000!important;width:3.8rem!important;height:3.8rem!important;min-width:3.8rem!important;min-height:3.8rem!important;border:0!important;background:#ffffff!important;color:#53665f!important;cursor:pointer!important;display:flex!important;align-items:center!important;justify-content:center!important;padding:0!important;border-radius:999px!important;box-shadow:0 0 0 1px rgba(83,102,95,.22)!important;line-height:1!important;opacity:1!important;visibility:visible!important;}\n.lulo-barcode-scan-button:hover,.lulo-barcode-scan-button:focus{background:#f3f7f5!important;outline:2px solid rgba(83,102,95,.2)!important;}\n.lulo-barcode-scan-button svg{width:2.1rem!important;height:2.1rem!important;display:block!important;pointer-events:none!important;}\n#lulo-barcode-scanner-modal[hidden]{display:none!important;}\n#lulo-barcode-scanner-modal{position:fixed;inset:0;z-index:999999;background:rgba(0,0,0,.78);display:flex;align-items:center;justify-content:center;padding:1.5rem;}\n.lulo-barcode-scanner-panel{width:min(92vw,460px);background:#fff;color:#121212;border-radius:18px;padding:1rem;box-shadow:0 20px 60px rgba(0,0,0,.35);text-align:center;}\n.lulo-barcode-scanner-panel h2{margin:.5rem 0 .25rem;font-size:1.4rem;}\n.lulo-barcode-scanner-panel p{margin:.25rem 0 1rem;font-size:1rem;}\n#lulo-barcode-video{width:100%;max-height:62vh;background:#111;border-radius:12px;object-fit:cover;}\n.lulo-barcode-close{margin-top:1rem;width:100%;min-height:44px;border:0;border-radius:999px;background:#ec5b66;color:#fff;font-weight:700;cursor:pointer;}\n';
    document.head.appendChild(style);
  }

  function makeCameraIcon(){
    return '<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M9 3.5 7.4 5.5H5a2.5 2.5 0 0 0-2.5 2.5v9A2.5 2.5 0 0 0 5 19.5h14a2.5 2.5 0 0 0 2.5-2.5V8A2.5 2.5 0 0 0 19 5.5h-2.4L15 3.5H9Zm3 5a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9Zm0 2a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5Z"></path></svg>';
  }

  var codeReader = null;

  function findSearchInputs(){
    return Array.prototype.slice.call(document.querySelectorAll('form[action*="/search"] input[type="search"], search-form input[type="search"], input[name="q"][type="search"]'));
  }

  function getModal(){
    var modal = document.getElementById(MODAL_ID);
    if (modal) return modal;
    modal = document.createElement('div');
    modal.id = MODAL_ID;
    modal.hidden = true;
    modal.innerHTML = '<div class="lulo-barcode-scanner-panel" role="dialog" aria-modal="true" aria-label="Barcode scanner"><h2>Scan ISBN barcode</h2><p>Point your camera at the book barcode.</p><video id="lulo-barcode-video" autoplay playsinline muted></video><button type="button" class="lulo-barcode-close">Close scanner</button></div>';
    document.body.appendChild(modal);
    modal.querySelector('.lulo-barcode-close').addEventListener('click', stopScanner);
    modal.addEventListener('click', function(event){ if (event.target === modal) stopScanner(); });
    return modal;
  }

  function stopScanner(){
    if (codeReader) {
      try { codeReader.reset(); } catch(e) {}
      codeReader = null;
    }
    var modal = document.getElementById(MODAL_ID);
    if (modal) modal.hidden = true;
  }

  function submitSearch(input, code){
    input.value = code;
    input.dispatchEvent(new Event('input', { bubbles: true }));
    input.dispatchEvent(new Event('change', { bubbles: true }));
    var form = input.form || input.closest('form');
    if (form) {
      if (typeof form.requestSubmit === 'function') form.requestSubmit();
      else form.submit();
    } else {
      window.location.href = '/search?q=' + encodeURIComponent(code);
    }
  }

  function startScanner(input){
    var modal = getModal();
    var video = modal.querySelector('#lulo-barcode-video');
    modal.hidden = false;

    loadZxing().then(function(){
      codeReader = new ZXing.BrowserMultiFormatReader();
      return codeReader.listVideoInputDevices();
    }).then(function(devices){
      var backCamera = devices.find(function(device){ return /back|rear|environment/i.test(device.label || ''); }) || devices[devices.length - 1] || null;
      return codeReader.decodeFromVideoDevice(backCamera && backCamera.deviceId, video, function(result){
        if (!result) return;
        var code = String(result.text || '').trim();
        if (!code) return;
        stopScanner();
        if (navigator.vibrate) navigator.vibrate(80);
        submitSearch(input, code);
      });
    }).catch(function(error){
      console.error('Barcode scanner error:', error);
      alert('Could not open the camera. Please allow camera access and try again.');
      stopScanner();
    });
  }

  function chooseAnchor(input){
    return input.closest('.field') || input.closest('form') || input.parentElement;
  }

  function enhanceSearchBars(){
    addStyles();
    findSearchInputs().forEach(function(input){
      var anchor = chooseAnchor(input);
      if (!anchor || anchor.querySelector('.' + BUTTON_CLASS)) return;
      input.dataset.luloBarcodeEnhanced = 'true';
      anchor.style.position = 'relative';
      var button = document.createElement('button');
      button.type = 'button';
      button.className = BUTTON_CLASS;
      button.setAttribute('aria-label', 'Scan ISBN barcode');
      button.title = 'Scan ISBN barcode';
      button.innerHTML = makeCameraIcon();
      button.addEventListener('click', function(event){
        event.preventDefault();
        event.stopPropagation();
        startScanner(input);
      });
      anchor.appendChild(button);
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', enhanceSearchBars);
  else enhanceSearchBars();
  window.addEventListener('load', enhanceSearchBars);
  document.addEventListener('click', function(){ setTimeout(enhanceSearchBars, 100); }, true);

  var observer = new MutationObserver(function(){ enhanceSearchBars(); });
  observer.observe(document.documentElement, { childList: true, subtree: true });
})();
